# Project Paper Research Skill configuration
# Copy this file to .env for local/private configuration.
# Do not commit .env to GitHub.

# -----------------------------
# Default free anonymous sources
# -----------------------------
# Recommended default: no account, no API key.
PAPER_RESEARCH_SOURCES=arxiv,crossref,dblp
ANONYMOUS_MODE=true

# Output language: zh-CN, en, or bilingual
PAPER_RESEARCH_LANGUAGE=zh-CN

# Search limits
PAPER_RESEARCH_MAX_RESULTS_PER_QUERY=10
PAPER_RESEARCH_MAX_PAPERS_TOTAL=50
PAPER_RESEARCH_REQUIRE_ACADEMIC_SOURCE=true

# Output files
PAPER_RESEARCH_OUTPUT_DIR=./research-output
PAPER_RESEARCH_MATRIX_FILE=paper_matrix.md
PAPER_RESEARCH_REPORT_FILE=literature_review_report.md
PAPER_RESEARCH_BIBTEX_FILE=references.bib

# Free anonymous API endpoints
ARXIV_API_BASE=https://export.arxiv.org/api/query
CROSSREF_API_BASE=https://api.crossref.org
DBLP_API_BASE=https://dblp.org/search/publ/api

# -----------------------------
# Optional sources with identity/key
# -----------------------------
# Keep these false for anonymous mode.
USE_SEMANTIC_SCHOLAR=false
USE_OPENALEX=false
USE_CROSSREF_POLITE_POOL=false
USE_GOOGLE_SCHOLAR=false

# Fill these only in your local .env, never in .env.example.
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
CROSSREF_MAILTO=

# -----------------------------
# Optional proxy
# -----------------------------
# Example:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=
HTTPS_PROXY=
